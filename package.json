{
  "name": "next-editor-workspace",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=next-editor && npm run build --workspace=demo",
    "dev": "npm run dev --workspace=demo",
    "lint": "npm run lint --workspaces --if-present"
  }
}
