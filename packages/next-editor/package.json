{
  "name": "@makeablebrand/next-editor",
  "version": "0.1.8",
  "description": "Drop-in CMS layer for custom Next.js sites.",
  "license": "MIT",
  "keywords": [
    "nextjs",
    "cms",
    "editor",
    "content-management",
    "postgres"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomas-mcgee/next-editor.git",
    "directory": "packages/next-editor"
  },
  "homepage": "https://github.com/thomas-mcgee/next-editor#readme",
  "bugs": {
    "url": "https://github.com/thomas-mcgee/next-editor/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./import": {
      "types": "./dist/import.d.ts",
      "import": "./dist/import.mjs",
      "require": "./dist/import.js",
      "default": "./dist/import.mjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "default": "./dist/client.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js",
      "default": "./dist/server.mjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs",
      "require": "./dist/auth/index.js",
      "default": "./dist/auth/index.mjs"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.mjs",
      "default": "./dist/admin/index.mjs"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "import": "./dist/handlers/index.mjs",
      "require": "./dist/handlers/index.js",
      "default": "./dist/handlers/index.mjs"
    },
    "./rich-text": {
      "types": "./dist/rich-text-editor.d.ts",
      "import": "./dist/rich-text-editor.mjs",
      "default": "./dist/rich-text-editor.mjs"
    },
    "./b2": {
      "types": "./dist/b2.d.ts",
      "import": "./dist/b2.mjs",
      "require": "./dist/b2.js",
      "default": "./dist/b2.mjs"
    },
    "./templates/pages-import.template.json": "./templates/pages-import.template.json",
    "./templates/collection-import.template.json": "./templates/collection-import.template.json",
    "./lexxy.css": "./styles/lexxy.css",
    "./styles/*.css": "./styles/*.css"
  },
  "sideEffects": [
    "./styles/*.css"
  ],
  "files": [
    "dist",
    "styles",
    "templates",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && tsup && mkdir -p dist/admin dist/auth && cp src/admin/index.d.ts dist/admin/index.d.ts && cp src/auth/index.d.ts dist/auth/index.d.ts && [ -f dist/client.d.mts ] && cp dist/client.d.mts dist/client.d.ts || true && [ -f dist/rich-text-editor.d.mts ] && cp dist/rich-text-editor.d.mts dist/rich-text-editor.d.ts || true",
    "prepack": "npm run build",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@37signals/lexxy": "^0.9.8-beta",
    "@aws-sdk/client-s3": "^3.1012.0",
    "@material-symbols-svg/react": "^0.5.0",
    "@rails/activestorage": "^8.1.200",
    "bcryptjs": "^3.0.3",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.4",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2"
  }
}
