{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "next": ["../../apps/demo/node_modules/next"],
      "next/*": ["../../apps/demo/node_modules/next/*"]
    },
    "typeRoots": ["../../apps/demo/node_modules/@types"]
  },
  "include": ["src/**/*"]
}
